{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "cppdbg",
            "request": "launch",
            "name": "(GDB) Debug RISC-V Kernel",
            "program": "build-x86_64/src/Kernel/RVOS",
            "args": [],
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "miDebuggerServerAddress": "localhost:1234",
            "setupCommands": [
                {
                    "text": "break main",
                    "ignoreFailures": false
                },
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                },
                {
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": false
                },
                {
                    "text": "-gdb-set output-radix 16",
                    "ignoreFailures": false
                },
                {
                    "text": "-interpreter-exec console \"skip -rfu std::.*\"",
                    "ignoreFailures": false
                },
                {
                    "text": "-interpreter-exec console \"skip -gfi */include/c++/v1/*\"",
                    "ignoreFailures": false
                }
            ],
            "preLaunchTask": "${defaultBuildTask}"
        },
        {
            //initCommands -> targetCreateCommands -> create breakpoints -> preRunCommands -> processCreateCommands -> postRunCommands -> debug
            "type": "lldb",
            "request": "launch",
            "name": "(LLDB) Debug RISC-V Kernel",
            "program": "build-x86_64/src/Kernel/RVOS",
            "cwd": "${workspaceFolder}",
            "postRunCommands": [
                // "breakpoint set -n _start",
                "breakpoint set -n main"
            ],
            "processCreateCommands": [
                "settings set target.default-arch riscv64",
                "settings set target.memory-module-load-level complete",
                "gdb-remote localhost:1234",
                "continue"
            ],
            // "stdio": [
            //     null,
            //     null,
            //     null
            // ]
            "sourceMap": {
                "/": "${workspaceFolder}/"
            },
            "preLaunchTask": "${defaultBuildTask}"
        }
    ],
    // "preLaunchTask": "${command:cmake.build}"
}
